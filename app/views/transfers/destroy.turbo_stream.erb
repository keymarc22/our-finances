<% if @transfer.present? %>
  <%= turbo_stream.replace dom_id(@transfer.money_account) do %>
    <%= render partial: "money_accounts/money_account", locals: { account: @transfer.money_account } %>
  <% end %>

  <% if @to_money_account.present? %>
    <%= turbo_stream.replace dom_id(@to_money_account) do %>
      <%= render partial: "money_accounts/money_account", locals: { account: @to_money_account } %>
    <% end %>
  <% end %>
<% end %>

<%= render_turbo_stream_flash_messages %>