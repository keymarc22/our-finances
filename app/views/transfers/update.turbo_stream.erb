<% if @transfer.valid? %>
  <%= turbo_stream.replace dom_id(@transfer) do %>
    <%= render TransactionComponent.new(transaction: @transfer) %>
  <% end %>

  <%= turbo_stream.replace dom_id(@transfer.money_account) do %>
    <%= render MoneyAccountComponent.new(money_account: @transfer.money_account.reload) %>
  <% end %>

  <% if @transfer.transferer_money_account %>
    <%= turbo_stream.replace dom_id(@transfer.transferer_money_account) do %>
      <%= render MoneyAccountComponent.new(money_account: @transfer.transferer_money_account.reload) %>
    <% end %>
  <% end %>
<% end %>

<%= render_turbo_stream_flash_messages %>