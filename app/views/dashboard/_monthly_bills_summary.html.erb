<% bills = dashboard.monthly_bills
   pending = dashboard.pending_monthly_bills
   total = dashboard.total_monthly_obligations
   paid_count = bills.count - pending.count
   paid_pct = bills.any? ? ((paid_count.to_f / bills.count) * 100).round : 0 %>

<%= turbo_frame_tag 'monthly_bills_summary' do %>
  <% if bills.any? %>
    <p class="text-md mb-3">Monthly bills</p>
    <%= render CardComponent.new(title: '', class: 'w-full border border-gray-200') do %>
      <div class="space-y-4 p-6 pt-2">

        <%# Overview %>
        <div>
          <div class="flex justify-between items-center mb-1">
            <span class="flex items-center gap-1.5 font-semibold text-sm">
              <%= lucide_icon 'calendar-clock', class: 'w-4 h-4', style: 'margin-right: 5px' %>
              This month
            </span>
            <span class="text-sm font-semibold">
              <%= paid_count %> / <%= bills.count %> paid
            </span>
          </div>
          <%= render ProgressBarComponent.new(percentage: paid_pct, color: '#6366f1', klass: 'mb-3') %>
          <div class="flex justify-between mt-1.5 text-xs text-gray-500">
            <span><%= to_money_format(total - pending.sum(&:amount)) %> paid</span>
            <% if pending.any? %>
              <span class="text-amber-600 font-medium"><%= to_money_format(pending.sum(&:amount)) %> pending</span>
            <% else %>
              <span class="text-green-600 font-medium">All paid!</span>
            <% end %>
          </div>
        </div>

        <hr class="border-gray-200" />

        <%# Bills list %>
        <div class="space-y-1">
          <% bills.each do |bill| %>
            <div class="flex items-center justify-between py-2 gap-3">
              <div class="flex items-center gap-2 flex-1 min-w-0">
                <% if bill.paid_this_month? %>
                  <span class="shrink-0 w-5 h-5 rounded-full bg-green-100 flex items-center justify-center">
                    <%= lucide_icon 'check', class: 'w-3 h-3 text-green-600' %>
                  </span>
                <% elsif bill.overdue? %>
                  <span class="shrink-0 w-5 h-5 rounded-full bg-red-100 flex items-center justify-center">
                    <%= lucide_icon 'alert-circle', class: 'w-3 h-3 text-red-500' %>
                  </span>
                <% else %>
                  <span class="shrink-0 w-5 h-5 rounded-full bg-gray-100 flex items-center justify-center">
                    <%= lucide_icon 'circle', class: 'w-3 h-3 text-gray-400' %>
                  </span>
                <% end %>

                <div class="flex-1 min-w-0">
                  <p class="text-sm <%= bill.paid_this_month? ? 'text-gray-400 line-through' : 'text-gray-800 font-medium' %> truncate">
                    <%= bill.name %>
                  </p>
                  <% if bill.due_day && !bill.paid_this_month? %>
                    <p class="text-xs <%= bill.overdue? ? 'text-red-500' : 'text-gray-400' %>">
                      Due <%= bill.due_day.ordinalize %>
                      <% if bill.overdue? %> · Overdue<% end %>
                    </p>
                  <% end %>
                </div>
              </div>

              <div class="flex items-center gap-2 shrink-0">
                <span class="text-sm <%= bill.paid_this_month? ? 'text-gray-400' : 'font-semibold text-gray-900' %>">
                  <%= to_money_format(bill.amount) %>
                </span>
                <% if bill.paid_this_month? %>
                  <span class="text-xs text-green-600 font-medium w-14 text-right">Paid</span>
                <% else %>
                  <%= link_to 'Pay',
                      new_monthly_bill_monthly_bill_payment_path(bill),
                      class: "text-xs font-medium px-2.5 py-1 rounded-md bg-gray-900 text-white hover:bg-gray-700 w-14 text-center",
                      'data-turbo-frame': "modal" %>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>

        <hr class="border-gray-200" />

        <div class="flex justify-between items-center text-sm">
          <span class="text-gray-500">Total</span>
          <span class="font-semibold"><%= to_money_format(total) %></span>
        </div>

        <div class="text-right">
          <%= link_to monthly_bills_path,
              class: "text-xs text-gray-400 hover:text-gray-700 flex items-center justify-end gap-1",
              data: { turbo_frame: "_top" } do %>
            <%= lucide_icon 'settings-2', class: 'w-3.5 h-3.5' %>
            Manage bills
          <% end %>
        </div>

      </div>
    <% end %>
  <% end %>
<% end %>
