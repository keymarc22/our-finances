<div id="expense-select" class="mb-6 hidden">
  <label class="<%= label_classes %>">Seleccionar de grupos de gatos</label>
  <select class="<%= select_classes %> p-0"
          data-action="change->expense-form#fillFields"
          data-controller="slimselect"
          data-slimselect-options-value="<%= {
            search: true,
            placeholder: 'Buscar o seleccionar un gasto...',
          }.to_json %>">
    <option value="">Select an option</option>
      <% current_account.expenses.fixed.group_by(&:transaction_group).each do |group, expenses| %>
        <optgroup label="<%= group.name %>">
          <% expenses.each do |expense| %>
            <option value="<%= expense.id %>"
                data-description="<%= expense.description %>"
                data-amount="<%= expense.amount_cents %>"
                data-date="<%= expense.transaction_date %>"
                data-budget="<%= expense.budget_id %>">
            <%= expense.description %>
            </option>
          <% end %>
        </optgroup>
      <% end %>
  </select>
</div>

<hr class="mb-6 border-gray-200"/>

<div>
  <div class="flex justify-end">
    <a href="#" class="text-sm flex gap-1 right" data-action="click->expense-form#clearFields">
      <%= lucide_icon 'brush-cleaning' %>
      Clean fields
    </a>
  </div>
  
  <%= f.input :amount, input_html: { min: 1, value: f.object.amount.zero? ? '' : f.object.amount, placeholder: '100.5', data: { expense_form_target: 'amount' } } %>

  <div class="grid gap-1 mb-6" data-controller="currency-toggle">
    <label class="<%= label_classes %>">Currency</label>
    <div class="flex items-center gap-3 mt-1">
      <span class="text-sm font-medium" data-currency-toggle-target="usdLabel">USD</span>
      <label class="relative inline-flex items-center cursor-pointer">
        <%= f.hidden_field :exchange_currency, value: 'USD', data: { currency_toggle_target: 'input' } %>
        <input type="checkbox" class="sr-only peer" data-action="change->currency-toggle#toggle" data-currency-toggle-target="checkbox">
        <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-gray-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-gray-900"></div>
      </label>
      <span class="text-sm font-medium" data-currency-toggle-target="vesLabel">VES</span>
    </div>

    <div class="mt-3 hidden" data-currency-toggle-target="exchangeRate">
      <label class="<%= label_classes %>">Exchange rate (VES → USD)</label>
      <input type="number" step="any" name="expense[exchange_rate]"
             class="mt-1 h-10 w-full rounded-md border border-gray-300 bg-background px-3 text-sm ring-offset-background placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2"
             placeholder="Ej: 78.50"
             data-currency-toggle-target="exchangeRateInput">
    </div>
  </div>

  <hr class="mb-6 border-gray-200"/>
  
  <%= f.input :description, input_html: { data: { expense_form_target: 'description' } } %>
  <%= f.input :money_account_id, as: :select, collection: current_account.money_accounts, prompt: 'Select an option', required: true %>
  <%= f.input :transaction_date, as: :string, input_html: { type: 'date', data: { expense_form_target: 'date' } } %>
  <%= f.input :budget_id, as: :select, collection: current_account.budgets, prompt: 'Select an option', input_html: { data: { expense_form_target: 'budget' } }, required: true  %>

  <div class="grid gap-1 mb-6 hidden" data-controller="toggable">
    <label class="<%= label_classes %>"></label>
    <%= f.collection_radio_buttons :transaction_type, [['personal', 'Personal'], ['shared', 'Compartido']], :first, :last do |builder| %>
      <%= builder.radio_button(id: "transaction-type-#{builder.value}", data: { action: 'change->toggable#toggle change->expense-form#getSplitsFields', target: '#percentage' }) %>
      <%= builder.label(class: label_classes) %>
    <% end %>
  </div>

  <hr class="mb-6 border-gray-200"/>

  <div class="grid gap-1 mb-6">
    <label class="<%= label_classes %>">Who paid?</label>
    
    <div class="flex gap-1">
      <%= f.collection_radio_buttons :user_id, User.all, :id, :name, selected: current_user %>
    </div>
  </div>
</div>