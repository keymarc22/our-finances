<% if @expense.valid? && @expense.persisted? %>
  <%= turbo_stream.prepend "expenses" do %>
    <%= render TransactionComponent.new(@expense) %>
  <% end %>

  <%= turbo_stream.prepend "money_account_expenses" do %>
    <%= render TransactionComponent.new(@expense) %>
  <% end %>

  <% if @expense.money_account %>
    <%= turbo_stream.replace dom_id(@expense.money_account) do %>
      <%= render MoneyAccountComponent.new(money_account: @expense.money_account) %>
    <% end %>
  <% end %>

  <% if @from_dashboard && @dashboard %>
    <%= turbo_stream.replace 'current_balance' do %>
      <%= render partial: 'dashboard/current_balance', locals: { dashboard: @dashboard } %>
    <% end %>

    <%= turbo_stream.replace 'budgets_summary' do %>
      <%= render partial: 'budgets/budget_summary', locals: { dashboard: @dashboard } %>
    <% end %>
  <% end %>
<% end %>

<%= render_turbo_stream_flash_messages %>
