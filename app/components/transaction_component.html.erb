<%= turbo_frame_tag dom_id(transaction) do %>
  <div class="border border-gray-200 p-4 shadow-sm rounded-lg hover:bg-gray-50 transition-colors mb-4 <%= options[:class] %>">
    <div class="grid grid-cols-[auto_1fr_auto] items-center">
      <div class="flex items-center p-3">
        <%= lucide_icon icon, style: "color: #{icon_color}", class: 'text-sm' %>
      </div>
      
      <!-- TITLE SECTION-->
      <div class="flex flex-col md:grid md:grid-cols-2">
        <h3 class="font-medium flex items-center order-1"><%= transaction.description %></h3>
        <span class="flex flex-wrap gap-1 mt-3 order-3 md:order-2 md:mt-0 md:justify-end md:items-start">
          <% if budget %>
            <%= render BadgeComponent.new text: budget.name, variant: transaction.shared? ? :default : :secondary, style: budget.color.present? ? "background-color: #{budget.color};" : nil %>
          <% end %>
          <% if transaction.try(:shared?) %>
            <%= render BadgeComponent.new text: "Shared", variant: :outline %>
          <% end %>

          <%= render BadgeComponent.new text: transaction.transaction_date&.strftime("%d %b %Y"), variant: :outline %>
        </span>
        <p class="text-xs text-gray-600 mt-1 w-full order-2 md:order-3 md:col-span-2">
          <% if transaction.user.present? %>
            • Paid for <%= transaction.user.name %>
          <% end %>

          <% if transaction.money_account %>
            • <%= transaction.money_account.try(:name) %>
          <% end %>
        </p>
      </div>
      
      <div class="flex items-center gap-2 pl-4">
        <% if transaction.respond_to?(:amount) %>
          <span class="font-semibold whitespace-nowrap" style="color: <%= icon_color %>">
            <%= number_to_currency(transaction.amount) %>
          </span>
        <% end %>
        <div class="relative inline-block text-left" data-controller="dropdown">
          <button type="button" data-action="click -> dropdown#toggle" class="inline-flex items-center justify-center rounded-md px-2 py-2 text-gray-600 hover:bg-gray-100 transition-colors" aria-expanded="false" aria-haspopup="true">
            <%= lucide_icon 'more-vertical', class: 'w-5 h-5' %>
          </button>
  
          <div class="hidden absolute right-0 z-10 mt-2 w-56 origin-top-right rounded-md bg-white shadow-lg ring-1 ring-black/5 focus:outline-hidden" role="menu" aria-orientation="vertical" tabindex="-1">
            <div class="py-1" role="none">
              <%= link_to 'Edit', edit_url, class: "block px-4 py-2 text-sm text-gray-700", 'data-turbo-frame': "modal" %>
              <%= link_to 'Delete', delete_url, class: "block px-4 py-2 text-sm text-gray-700", data: { 'turbo-method': 'delete', "turbo-confirm": '¿Estas seguro? No se podrá revertir' }  %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
<% end %>